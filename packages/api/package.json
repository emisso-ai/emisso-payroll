{
  "name": "@emisso/payroll-api",
  "version": "0.2.6",
  "description": "Full payroll API layer — routes, services, and database for @emisso/payroll-cl",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/adapters/next.d.ts",
      "import": "./dist/adapters/next.js",
      "require": "./dist/adapters/next.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest --run",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:deploy": "drizzle-kit push",
    "db:deploy:dry": "drizzle-kit push --dry-run"
  },
  "keywords": [
    "payroll",
    "chile",
    "api",
    "supabase",
    "drizzle",
    "self-hosted",
    "multi-tenant",
    "effect-ts",
    "next-js",
    "rest-api",
    "remuneraciones"
  ],
  "author": "Emisso <hello@emisso.ai>",
  "license": "MIT",
  "homepage": "https://github.com/emisso-ai/emisso-payroll",
  "bugs": {
    "url": "https://github.com/emisso-ai/emisso-payroll/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emisso-ai/emisso-payroll",
    "directory": "packages/api"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@emisso/payroll-cl": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.1",
    "postgres": "^3.4.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
