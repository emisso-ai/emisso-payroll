{
  "name": "@emisso/payroll-cli",
  "version": "0.2.7",
  "description": "CLI for Chilean payroll calculations — AFP, health, tax, Previred, and more",
  "type": "module",
  "main": "./dist/src/index.cjs",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "payroll": "./dist/bin/payroll.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest --run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "payroll",
    "chile",
    "cli",
    "remuneraciones",
    "afp",
    "previred",
    "liquidacion",
    "impuestos",
    "finiquito",
    "typescript",
    "sdk"
  ],
  "author": "Emisso <hello@emisso.ai>",
  "license": "MIT",
  "homepage": "https://github.com/emisso-ai/emisso-payroll",
  "bugs": {
    "url": "https://github.com/emisso-ai/emisso-payroll/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emisso-ai/emisso-payroll",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@emisso/payroll-cl": "workspace:*",
    "@emisso/cli-core": "^0.1.0",
    "effect": "^3.21.1",
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
